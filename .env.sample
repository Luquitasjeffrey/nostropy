# Rename this file to `.env` and fill in your environment-specific values.

# MongoDB connection string used by mongoose
MONGODB_URI=mongodb://mongoadmin:secret@localhost:27017/nostropy

# Nostr configuration (example placeholders)
NOSTR_RELAY_URL=wss://relay.example.com
NOSTR_PRIVATE_KEY=your_private_key_here

# jwt configuration 
JWT_SECRET=strong_secret

# Server configuration
HOST=0.0.0.0
DICE_HOUSE_EDGE=0.01
FORK_HOUSE_EDGE=0.02
MINES_HOUSE_EDGE=0.02
PORT=5000
